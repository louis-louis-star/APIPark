# ============================================================
# APIPark 部署配置文件
# 使用方式: 复制此文件为 .env 并修改配置
#   cp .env.example .env
#   vim .env
# ============================================================

# ----------------
# 镜像配置
# ----------------
# APIPark 镜像地址（支持私有仓库）
APIPARK_IMAGE=apipark/apipark:latest

# Docker 私有仓库地址（如有）
# DOCKER_REGISTRY=your-registry.com

# ----------------
# 端口配置
# ----------------
# APIPark 控制台端口
APIPARK_PORT=18288

# MySQL 端口（外部访问）
MYSQL_PORT=33306

# Redis 端口（外部访问）
REDIS_PORT=6379

# InfluxDB 端口（外部访问）
INFLUXDB_PORT=8086

# Apinto Gateway 代理端口
APINTO_PROXY_PORT=8099

# Apinto 管理端口
APINTO_ADMIN_PORT=9400

# ----------------
# 密码配置（请修改！）
# ----------------
# MySQL root 密码
MYSQL_ROOT_PASSWORD=your_mysql_password_here

# Redis 密码
REDIS_PASSWORD=your_redis_password_here

# APIPark 管理员密码
ADMIN_PASSWORD=your_admin_password_here

# ----------------
# 数据存储配置
# ----------------
# 数据存储根目录
DATA_DIR=/var/lib/apipark

# ----------------
# InfluxDB 配置
# ----------------
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=Key123qaz
INFLUXDB_ADMIN_TOKEN=dQ9>fK6&gJ
INFLUXDB_ORG=apipark

